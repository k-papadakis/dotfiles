{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "command_list": "<leader>p",
    "input_submit": "return,ctrl+m",
    "input_backspace": "backspace,shift+backspace,ctrl+h",
    "history_previous": "up,ctrl+p",
    "history_next": "down,ctrl+n",
  },
  "attention": {
    "enabled": true,
  },
}
